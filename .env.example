# Prisma database connection string.
#
# Production (Vercel + Vercel Postgres, Neon, Supabase, or any hosted Postgres):
#   Create a Postgres database on Vercel (Storage tab → Create Database → Postgres)
#   Copy the `postgres://` connection string and paste it here:
DATABASE_URL="postgresql://user:password@host:5432/database?pgbouncer=true&connection_limit=1"
#
# Local development (SQLite — works locally but NOT on Vercel serverless):
#   1. Switch prisma/schema.prisma `provider` back to "sqlite"
#   2. Use a file path:
# DATABASE_URL="file:./db/custom.db"


# ─────────────────────────────────────────────────────────────────────────────
# z-ai-web-dev-sdk credentials (required for the AI math solver)
#
# The SDK normally reads from a .z-ai-config file, but that doesn't work on
# serverless platforms (no writable filesystem). The app constructs the SDK
# client directly from these env vars instead.
#
# Get these values from your z.ai account dashboard or your local
# /etc/.z-ai-config / ~/.z-ai-config file.
# ─────────────────────────────────────────────────────────────────────────────
ZAI_BASE_URL="https://internal-api.z.ai/v1"
ZAI_API_KEY="Z.ai"
ZAI_TOKEN="your-jwt-token-here"
ZAI_USER_ID="your-user-uuid-here"
ZAI_CHAT_ID="optional-chat-session-uuid"
