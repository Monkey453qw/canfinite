# Prisma database connection string.
#
# Production (Vercel + Vercel Postgres, Neon, Supabase, or any hosted Postgres):
#   Create a Postgres database on Vercel (Storage tab → Create Database → Postgres)
#   Copy the `postgres://` connection string and paste it here:
DATABASE_URL="postgresql://user:password@host:5432/database?pgbouncer=true&connection_limit=1"
#
# Local development (SQLite — works locally but NOT on Vercel serverless):
#   1. Switch prisma/schema.prisma `provider` back to "sqlite"
#   2. Use a file path:
# DATABASE_URL="file:./db/custom.db"
